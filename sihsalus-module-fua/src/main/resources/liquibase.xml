<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Tabla fua_estado -->
    <changeSet id="fua_estado-2025-12-07-01" author="pedro">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="fua_estado"/></not>
        </preConditions>
        <createTable tableName="fua_estado">
            <column name="fua_estado_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="uuid" type="char(38)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="nombre" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_creacion" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_actualizacion" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="int" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="activo" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Tabla fua -->
    <changeSet id="fua-2025-12-07-01" author="pedro">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="fua"/></not>
        </preConditions>
        <createTable tableName="fua">
            <column name="fua_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="uuid" type="char(38)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="visit_uuid" type="char(38)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="clob"/>
            <column name="fua_estado_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_creacion" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_actualizacion" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="int" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="activo" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="fua"
                                 baseColumnNames="visit_uuid"
                                 referencedTableName="visit"
                                 referencedColumnNames="uuid"
                                 constraintName="fk_fua_visit"/>

        <addForeignKeyConstraint baseTableName="fua"
                                 baseColumnNames="fua_estado_id"
                                 referencedTableName="fua_estado"
                                 referencedColumnNames="fua_estado_id"
                                 constraintName="fk_fua_estado"/>
    </changeSet>

    <!-- Tabla fua_version -->
    <changeSet id="fua_version-2025-12-07-01" author="pedro">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="fua_version"/></not>
        </preConditions>
        <createTable tableName="fua_version">
            <column name="fua_version_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="uuid" type="char(38)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="fua_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="fua_uuid" type="char(38)">
                <constraints nullable="false"/>
            </column>
            <column name="visit_uuid" type="char(38)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="clob"/>
            <column name="fua_estado_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="descripcion" type="varchar(255)"/>
            <column name="fecha_creacion" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_actualizacion" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="activo" type="boolean">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="fua_version"
                                baseColumnNames="fua_id"
                                referencedTableName="fua"
                                referencedColumnNames="fua_id"
                                constraintName="fk_fua_version_fua"/>

        <addForeignKeyConstraint baseTableName="fua_version"
                                baseColumnNames="visit_uuid"
                                referencedTableName="visit"
                                referencedColumnNames="uuid"
                                constraintName="fk_fua_version_visit"/>

        <addForeignKeyConstraint baseTableName="fua_version"
                                baseColumnNames="fua_estado_id"
                                referencedTableName="fua_estado"
                                referencedColumnNames="fua_estado_id"
                                constraintName="fk_fua_version_estado"/>
    </changeSet>


    <!-- Tabla fua_estado_version -->
    <changeSet id="fua_estado_version-2025-12-07-01" author="pedro">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="fua_estado_version"/></not>
        </preConditions>
        <createTable tableName="fua_estado_version">
            <column name="fua_estado_version_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="uuid" type="char(38)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="fua_estado_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="fua_estado_uuid" type="char(38)">
                <constraints nullable="false"/>
            </column>
            <column name="nombre" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="descripcion" type="varchar(255)"/>
            <column name="fecha_creacion" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_actualizacion" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="activo" type="boolean">
                <constraints nullable="false"/>
            </column>
        </createTable>


        <addForeignKeyConstraint baseTableName="fua_estado_version"
                                baseColumnNames="fua_estado_id"
                                referencedTableName="fua_estado"
                                referencedColumnNames="fua_estado_id"
                                constraintName="fk_fua_estado_version_estado"/>
    </changeSet>

    <!-- Trigger para actualizar fecha_actualizacion -->
    <changeSet id="trigger_fua_fechaActualizacion-2025-12-07-01" author="pedro" dbms="mysql">
        <comment>Trigger para actualizar automáticamente fecha_actualizacion en cada UPDATE en fua</comment>
        <sql>
            CREATE TRIGGER trg_fua_update_timestamp
            BEFORE UPDATE ON fua
            FOR EACH ROW
            SET NEW.fecha_actualizacion = CURRENT_TIMESTAMP;
        </sql>
    </changeSet>

    <!-- Trigger para actualizar fecha_actualizacion en fua_estado -->
    <changeSet id="trigger_fua_estado_fechaActualizacion-2025-12-07-01" author="pedro" dbms="mysql">
        <comment>Trigger para actualizar automáticamente fecha_actualizacion en cada UPDATE en fua_estado</comment>
        <sql>
            CREATE TRIGGER trg_fua_estado_update_timestamp
            BEFORE UPDATE ON fua_estado
            FOR EACH ROW
            SET NEW.fecha_actualizacion = CURRENT_TIMESTAMP;
        </sql>
    </changeSet>

    <!-- Agregar columnas de fua-generator uuid a las tablas de fua y fuaversion -->
    <changeSet id="add-fua-generator-uuid-2026-02-12-01" author="pedro">

        <addColumn tableName="fua">
            <column name="fua_generator_uuid" type="varchar(38)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn tableName="fua_version">
            <column name="fua_generator_uuid" type="varchar(38)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

    </changeSet>


    <changeSet id="sihsalus-fua-create-static-privileges-20260519" author="sihsalus">
        <comment>Create FUA privileges normally loaded from config.xml by the OMOD runtime.</comment>
        <sql splitStatements="true">
            INSERT INTO privilege (privilege, description, uuid)
            SELECT 'Fua Privilege', 'Allows user to access general FUA module functions', '128f8894-4428-42e9-943a-77a13aa2e6c0'
            WHERE NOT EXISTS (SELECT 1 FROM privilege WHERE privilege = 'Fua Privilege');

            INSERT INTO privilege (privilege, description, uuid)
            SELECT 'Read Fua', 'Allows user to view FUA records', 'a419d593-1e7e-4460-b75b-a4b85780c721'
            WHERE NOT EXISTS (SELECT 1 FROM privilege WHERE privilege = 'Read Fua');

            INSERT INTO privilege (privilege, description, uuid)
            SELECT 'Manage Fua', 'Allows user to create and manage FUA records', '6d826cb0-00ca-4f1e-9270-78f9b0c20a8d'
            WHERE NOT EXISTS (SELECT 1 FROM privilege WHERE privilege = 'Manage Fua');

            INSERT INTO privilege (privilege, description, uuid)
            SELECT 'Delete Fua', 'Allows user to delete FUA records', 'ad6e1f62-35a3-4a7d-a936-0965a5b00c9c'
            WHERE NOT EXISTS (SELECT 1 FROM privilege WHERE privilege = 'Delete Fua');

            INSERT INTO privilege (privilege, description, uuid)
            SELECT 'Update Fua', 'Allows user to update FUA records', '12048d96-e027-4f6d-938e-23ab2bd3dcaf'
            WHERE NOT EXISTS (SELECT 1 FROM privilege WHERE privilege = 'Update Fua');
        </sql>
    </changeSet>

    <changeSet id="sihsalus-fua-create-static-global-properties-20260519" author="sihsalus">
        <comment>Create FUA global properties normally loaded from config.xml by the OMOD runtime.</comment>
        <sql splitStatements="true">
            INSERT INTO global_property (property, property_value, description, uuid)
            SELECT 'fua.generator.url', 'http://fua-generator:3000',
                   'Base URL of the FUA Generator microservice. This service is responsible for rendering FUA documents as HTML.',
                   '4980db7f-30fb-4a27-adba-670bf9e9fe2e'
            WHERE NOT EXISTS (SELECT 1 FROM global_property WHERE property = 'fua.generator.url');

            INSERT INTO global_property (property, property_value, description, uuid)
            SELECT 'fua.identifier', '',
                   'Identifier used by the FUA module. This is a configurable string value that can be set by the administrator and used when communicating with external FUA-related services.',
                   '1de77e9e-c42e-447a-866f-465ffcb06e17'
            WHERE NOT EXISTS (SELECT 1 FROM global_property WHERE property = 'fua.identifier');
        </sql>
    </changeSet>


</databaseChangeLog>
