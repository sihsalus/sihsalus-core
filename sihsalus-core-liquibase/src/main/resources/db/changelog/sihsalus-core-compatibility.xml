<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="sihsalus-core-compatibility-20260513-01" author="sihsalus">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="person_attribute"/>
            <not>
                <columnExists tableName="person_attribute" columnName="value"/>
            </not>
        </preConditions>
        <comment>Add person_attribute.value required by the current OpenMRS JPA mapping.</comment>
        <addColumn tableName="person_attribute">
            <column name="value" type="VARCHAR(50)" defaultValue="">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="sihsalus-core-compatibility-20260513-01-h2" author="sihsalus" dbms="h2">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="person_attribute"/>
        </preConditions>
        <comment>Add unquoted person_attribute.value for Hibernate on H2 PostgreSQL mode.</comment>
        <sql>ALTER TABLE person_attribute ADD COLUMN IF NOT EXISTS value VARCHAR(50) DEFAULT '' NOT NULL</sql>
    </changeSet>

    <changeSet id="sihsalus-core-compatibility-20260513-02" author="sihsalus">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="person_attribute"/>
            <columnExists tableName="person_attribute" columnName="value"/>
            <columnExists tableName="person_attribute" columnName="value_reference"/>
        </preConditions>
        <comment>Backfill legacy person_attribute values when only value_reference was populated.</comment>
        <sql>
            UPDATE person_attribute
            SET value = LEFT(value_reference, 50)
            WHERE (value IS NULL OR value = '')
              AND value_reference IS NOT NULL
        </sql>
    </changeSet>

    <changeSet id="sihsalus-core-compatibility-20260513-03-h2-person-attribute-value" author="sihsalus" dbms="h2">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="person_attribute"/>
        </preConditions>
        <comment>Keep H2 aligned with the PersonAttribute JPA mapping used by the static core boot tests.</comment>
        <sql>
            ALTER TABLE person_attribute ADD COLUMN IF NOT EXISTS value VARCHAR(50) DEFAULT '' NOT NULL;
            UPDATE person_attribute
            SET value = LEFT(value_reference, 50)
            WHERE (value IS NULL OR value = '')
              AND value_reference IS NOT NULL;
            </sql>
    </changeSet>

    <changeSet id="sihsalus-core-compatibility-20260513-04-fhir-patient-identifier-system" author="sihsalus">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="fhir_patient_identifier_system"/>
            </not>
            <tableExists tableName="patient_identifier_type"/>
            <tableExists tableName="users"/>
        </preConditions>
        <comment>Add FHIR2 patient identifier system metadata table for static module boot.</comment>
        <createTable tableName="fhir_patient_identifier_system">
            <column name="fhir_patient_identifier_system_id" type="int" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="patient_identifier_type_id" type="int"/>
            <column name="url" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(255)"/>
            <column name="creator" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="changed_by" type="int"/>
            <column name="date_changed" type="datetime"/>
            <column name="retired" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="retired_by" type="int"/>
            <column name="date_retired" type="datetime"/>
            <column name="retire_reason" type="varchar(255)"/>
            <column name="uuid" type="varchar(38)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="fhir_patient_identifier_system"
                                 baseColumnNames="patient_identifier_type_id"
                                 constraintName="fhir_patient_identifier_system_patient_identifier_type_fk"
                                 referencedTableName="patient_identifier_type"
                                 referencedColumnNames="patient_identifier_type_id"/>
        <addForeignKeyConstraint baseTableName="fhir_patient_identifier_system"
                                 baseColumnNames="creator"
                                 constraintName="fhir_patient_identifier_system_creator_fk"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"/>
        <addForeignKeyConstraint baseTableName="fhir_patient_identifier_system"
                                 baseColumnNames="changed_by"
                                 constraintName="fhir_patient_identifier_system_changed_by_fk"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"/>
        <addForeignKeyConstraint baseTableName="fhir_patient_identifier_system"
                                 baseColumnNames="retired_by"
                                 constraintName="fhir_patient_identifier_system_retired_by_fk"
                                 referencedTableName="users"
                                 referencedColumnNames="user_id"/>
    </changeSet>
</databaseChangeLog>
