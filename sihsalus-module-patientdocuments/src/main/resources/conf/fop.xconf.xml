<fop version="1.0">

  <!-- Strict user configuration -->
  <strict-configuration>true</strict-configuration>

  <!-- Strict FO validation -->
  <strict-validation>true</strict-validation>

  <!-- Base URL for resolving relative URLs -->
  <base>.</base>

  <!-- Font Base URL for resolving relative font URLs -->
  <renderers>
    <renderer mime="application/pdf">
      <!-- Font configuration -->
      <fonts>    
        <font kerning="yes" embed-url="./IBMPlexSansArabic-Regular.ttf">
          <font-triplet name="IBM Plex Sans Arabic" style="normal" weight="normal"/>
        </font>
        <font kerning="yes" embed-url="./IBMPlexSansArabic-Bold.ttf">
          <font-triplet name="IBM Plex Sans Arabic Bold" style="normal" weight="900"/>
        </font>
      </fonts> 
    </renderer>
  </renderers>
</fop>
